local function CreateIcon(imagePath, parent, props)
	local img = Instance.new("ImageLabel")
	img.Size = (props and props.Size) or UDim2.new(0, s(12), 0, s(12))
	img.Position = (props and props.Position) or UDim2.new(0.5, -s(8), 0.5, -s(8))
	img.BackgroundTransparency = 1
	img.Image = imagePath or ""
	if props and props.ImageColor3 then img.ImageColor3 = props.ImageColor3 end
	if props and props.ImageTransparency then img.ImageTransparency = props.ImageTransparency end
	img.Parent = parent
	return img
end

