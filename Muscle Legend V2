function UILibrary:ApplyTheme(themeIndex)
	local theme = themes[themeIndex] or themes[1]
	config.currentTheme = themeIndex
	if self.mainFrame then TweenService:Create(self.mainFrame, TweenInfo.new(0.3), { BackgroundColor3 = theme.background }):Play() end
	if self.sidebar then TweenService:Create(self.sidebar, TweenInfo.new(0.3), { BackgroundColor3 = theme.sidebar }):Play() end
	if self.sidebarStroke then TweenService:Create(self.sidebarStroke, TweenInfo.new(0.3), { Color = theme.stroke }):Play() end
	if self.userSectionStroke then TweenService:Create(self.userSectionStroke, TweenInfo.new(0.3), { Color = theme.stroke }):Play() end
	local function setGradient(grad, c1, c2)
		if grad then
			grad.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, c1),
				ColorSequenceKeypoint.new(1, c2)
			})
		end
	end
	if self.avatarGradient then setGradient(self.avatarGradient, theme.primary1, theme.primary2) end
	if self.userAvatar then TweenService:Create(self.userAvatar, TweenInfo.new(0.3), { BackgroundColor3 = theme.primary1 }):Play() end
	if self.userStatus then TweenService:Create(self.userStatus, TweenInfo.new(0.3), { TextColor3 = theme.primary1 }):Play() end
	for _, tab in pairs(self.tabs) do tab:UpdateTheme(theme) end
	for _, themeData in pairs(self.themeElements) do
		if themeData.element and themeData.element.Parent then
			if themeData.elementType == "toggle_active" then
				TweenService:Create(themeData.element, TweenInfo.new(0.3), { BackgroundColor3 = theme.primary1 }):Play()
				if themeData.properties and themeData.properties.gradient then
					setGradient(themeData.properties.gradient, theme.primary1, theme.primary2)
				end
			elseif themeData.elementType == "toggle_inactive" then
				TweenService:Create(themeData.element, TweenInfo.new(0.3), { BackgroundColor3 = theme.toggleOff }):Play()
			elseif themeData.elementType == "slider_fill" then
				TweenService:Create(themeData.element, TweenInfo.new(0.3), { BackgroundColor3 = theme.primary1 }):Play()
				if themeData.properties and themeData.properties.gradient then
					setGradient(themeData.properties.gradient, theme.primary1, theme.primary2)
				end
			elseif themeData.elementType == "slider_track" then
				TweenService:Create(themeData.element, TweenInfo.new(0.3), { BackgroundColor3 = theme.trackBg }):Play()
			elseif themeData.elementType == "slider_thumb_stroke" then
				TweenService:Create(themeData.element, TweenInfo.new(0.3), { Color = theme.primary1 }):Play()
			elseif themeData.elementType == "dropdown_bg" then
				TweenService:Create(themeData.element, TweenInfo.new(0.3), { BackgroundColor3 = theme.elementBg }):Play()
			elseif themeData.elementType == "input_bg" then
				TweenService:Create(themeData.element, TweenInfo.new(0.3), { BackgroundColor3 = theme.elementBg }):Play()
			elseif themeData.elementType == "button" then
				TweenService:Create(themeData.element, TweenInfo.new(0.3), { BackgroundColor3 = theme.primary1 }):Play()
				if themeData.properties and themeData.properties.gradient then
					setGradient(themeData.properties.gradient, theme.primary1, theme.primary2)
				end
			elseif themeData.elementType == "keybind_stroke" then
				TweenService:Create(themeData.element, TweenInfo.new(0.3), { Color = theme.primary1 }):Play()
			end
		end
	end
end
