function UILibrary:ToggleMinimize()
	if self._minimizeAnimating then return end
	self.isMinimized = not self.isMinimized
	if not self._originalGeometry then
		self._originalGeometry = {
			Size = self.mainFrame.Size,
			Position = self.mainFrame.Position
		}
	end
	if self.isMinimized then
		self._minimizeAnimating = true
		local tween = TweenService:Create(self.mainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
			Size = UDim2.new(0, s(260), 0, s(38)),
			Position = UDim2.new(0.5, -s(130), 0, s(16))
		})
		tween:Play()
		tween.Completed:Connect(function()
			if self.sidebar then self.sidebar.Visible = false end
			if self.mainContent then self.mainContent.Visible = false end
			self._minimizeAnimating = false
		end)
	else
		self._minimizeAnimating = true
		if self.sidebar then self.sidebar.Visible = true end
		if self.mainContent then self.mainContent.Visible = true end
		local tween = TweenService:Create(self.mainFrame, TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			Size = self._originalGeometry and self._originalGeometry.Size or UDim2.new(0, GUI_W, 0, GUI_H),
			Position = self._originalGeometry and self._originalGeometry.Position or UDim2.new(0.5, -GUI_W / 2, 0.5, -GUI_H / 2)
		})
		tween:Play()
		tween.Completed:Connect(function()
			self._minimizeAnimating = false
		end)
	end
end
function UILibrary:Close()
	TweenService:Create(self.mainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
		Size = UDim2.new(0, 0, 0, 0),
		Position = UDim2.new(0.5, 0, 0.5, 0)
	}):Play()
	wait(0.5)
	self.screenGui:Destroy()
end
